{
  "name": "octorelease",
  "private": true,
  "description": "Extensible GitHub action to publish semantic releases.",
  "main": "index.js",
  "bin": "dist/index.js",
  "scripts": {
    "build": "tsc -b --force",
    "lint": "eslint packages/**/*.ts",
    "pack": "npm run pack --workspaces",
    "test": "jest",
    "typedoc": "typedoc --plugin typedoc-plugin-markdown --out docs/typedoc packages/core/src/index.ts",
    "watch": "tsc -w",
    "all": "npm run build && npm run lint && npm run pack && npm test",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zowe-actions/octorelease.git"
  },
  "keywords": [],
  "author": "t1m0thyj",
  "license": "Apache-2.0",
  "workspaces": [
    "packages/*",
    "script"
  ],
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-license-header": "^0.9.0",
    "globals": "^17.5.0",
    "husky": "^9.0.11",
    "jest": "^30.3.0",
    "jest-circus": "^30.3.0",
    "ts-jest": "^29.4.0",
    "typedoc": "^0.28.0",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.4.0"
  }
}
