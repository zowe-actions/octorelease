			"path": "packages/git"
		},
		{
			"path": "packages/github"
		},
		{
			"path": "packages/lerna"
		},
		{
			"path": "packages/npm"
		},
		{
			"path": "packages/vsce"
		},
		{
			"path": "script"
		},
	]
